{
	"name": "desk",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/desk/src",
	"projectType": "application",
	"tags": [],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "webpack-cli build",
				"args": [
					"--node-env=production"
				],
				"cwd": "apps/desk"
			},
			"configurations": {
				"development": {
					"args": [
						"--node-env=development"
					]
				}
			}
		},
		"docker": {
			"executor": "nx:run-commands",
			"options": {
				"command": "VERSION=$(node -p \"require('./apps/desk/package.json').version\") && docker build -f apps/desk/Dockerfile -t lvdesk:$VERSION -t lvdesk:latest --build-arg VERSION=$VERSION ."
			}
		},
		"serve": {
			"continuous": true,
			"executor": "@nx/js:node",
			"defaultConfiguration": "development",
			"dependsOn": [
				"build"
			],
			"options": {
				"buildTarget": "desk:build",
				"runBuildTargetDependencies": false
			},
			"configurations": {
				"development": {
					"buildTarget": "desk:build:development"
				},
				"production": {
					"buildTarget": "desk:build:production"
				}
			}
		}
	}
}
